{
  "name": "jellochat",
  "version": "1.1.2",
  "description": "Electron chat app with PostgreSQL",
  "author": "JelloChat",
  "license": "AGPL-3.0-or-later",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "sync:web-vendor": "node scripts/sync-web-vendor.js",
    "web": "npm run sync:web-vendor && node server.js",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage",
    "build:linux:dir": "electron-builder --linux dir",
    "flatpak:prepare": "node scripts/prepare-flatpak.js",
    "build:flatpak": "npm run build:linux:dir && npm run flatpak:prepare && flatpak-builder --force-clean --user --install-deps-from=flathub dist/flatpak-build flatpak/com.jellochat.app.yml",
    "sync:android-assets": "node scripts/sync-android-assets.js",
    "cap:sync": "npm run sync:web-vendor && npm run sync:android-assets && npx cap sync android",
    "cap:open": "npx cap open android",
    "prepare:fdroid": "npm run cap:sync && node scripts/prepare-fdroid.js",
    "build:fdroid": "npm run prepare:fdroid && cd android && gradlew.bat assembleFdroidRelease",
    "build:apk": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^7.6.0",
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.6.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "livekit-client": "^2.15.7",
    "livekit-server-sdk": "^2.13.2",
    "marked": "^12.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3",
    "typescript": "^5.9.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.jellochat.app",
    "productName": "JelloChat",
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "mailer.js",
      "server.js",
      "docs/**/*",
      "sql/**/*",
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "assets/image.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/app-icon-1024.png",
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Network"
    }
  }
}
